# ──────────────────────────────────────────────
# School Management System — Environment Config
# ──────────────────────────────────────────────
# Copy this file to .env and adjust values:
#   cp .env.example .env
# Then run: make deploy
# ──────────────────────────────────────────────

# ── PostgreSQL ─────────────────────────────────
POSTGRES_DB=school
POSTGRES_USER=school
POSTGRES_PASSWORD=change-me-to-a-strong-password

# ── JWT Authentication ────────────────────────
# Must be at least 32 characters. On first deploy the script generates one.
JWT_SECRET=change-this-to-a-random-256-bit-secret
JWT_ACCESS_TOKEN_MINUTES=60

# ── MinIO (file storage) ──────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin-secret

# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=120

# ── Docker Compose project name ──────────────
COMPOSE_PROJECT_NAME=school-management

# ── Image tags (change to your registry if pushing) ──
# If you push images to a registry, set these to your
# image names and uncomment to skip local builds.
# AUTH_SERVICE_IMAGE=school-management/auth-service:latest
# FRONTEND_IMAGE=school-management/frontend:latest
